NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://rideme:rideme_secret@localhost:5432/rideme

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your_access_secret_min_32_chars_long_please
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_long_please
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# Resend Email
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@rideme.ink

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_PER_TRIP_AMOUNT=150

# Google Maps
GOOGLE_MAPS_API_KEY=...

# AWS S3 (file uploads)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=rideme-documents

# App
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000

